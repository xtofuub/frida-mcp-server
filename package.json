{
  "name": "frida-mcp-server",
  "version": "1.5.1",
  "description": "MCP server for iOS app inspection with Frida — zero FLEX dependency. Ships an autonomous orchestration kit (slash commands + subagents).",
  "mcpName": "io.github.xtofuub/frida-mcp-server",
  "bin": {
    "frida-mcp-server": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "skills/",
    ".claude/commands/",
    ".claude/agents/",
    "scripts/",
    "memory/README.md",
    "frida_mcp_server.py",
    "mcp.config.example.jsonc",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/cli.js serve",
    "install:mcp": "node bin/cli.js install",
    "register": "node bin/cli.js register",
    "config": "node bin/cli.js config",
    "doctor": "node bin/cli.js doctor"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "frida",
    "frida-ios-dump",
    "ios",
    "reverse-engineering",
    "mobile-security",
    "pentest"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xtofuub/frida-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/xtofuub/frida-mcp-server/issues"
  },
  "homepage": "https://github.com/xtofuub/frida-mcp-server#readme",
  "license": "MIT"
}
